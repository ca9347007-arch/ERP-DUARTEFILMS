generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  FINANCE
  ATTENDANT
  INSTALLER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_SERVICE
  FINISHED
  CANCELLED
  NO_SHOW
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING
  FINISHED
  CANCELLED
}

enum FinancialType {
  REVENUE
  EXPENSE
}

enum FinancialStatus {
  PENDING
  RECEIVED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  PIX_MANUAL
  TRANSFER
  OTHER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  clients           Client[]
  vehicles          Vehicle[]
  services          Service[]
  appointments      Appointment[]
  quotes            Quote[]
  workOrders        WorkOrder[]
  products          Product[]
  stockMovements    StockMovement[]
  financialEntries  FinancialEntry[]
  auditLogs         AuditLog[]
  settings          Setting[]
}

model User {
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  appointmentsAssigned Appointment[] @relation("AssignedInstaller")
  auditLogs            AuditLog[]
  stockMovements       StockMovement[]

  @@index([companyId])
}

model Client {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  phone     String
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles     Vehicle[]
  appointments Appointment[]
  quotes       Quote[]

  @@index([companyId])
  @@index([phone])
}

model Vehicle {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  plate     String?
  brand     String?
  model     String
  year      Int?
  color     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  quotes       Quote[]
  workOrders   WorkOrder[]

  @@index([companyId])
  @@index([clientId])
}

model Service {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  description     String?
  basePriceCents  Int      @default(0)
  durationMinutes Int      @default(60)
  isPublic        Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
  quoteItems   QuoteItem[]

  @@index([companyId])
}

model Appointment {
  id            String            @id @default(uuid())
  publicCode    String            @unique
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id])
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  vehicleId     String?
  vehicle       Vehicle?          @relation(fields: [vehicleId], references: [id])
  serviceId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  installerId   String?
  installer     User?             @relation("AssignedInstaller", fields: [installerId], references: [id])
  startsAt      DateTime
  endsAt        DateTime
  status        AppointmentStatus @default(PENDING)
  source        String            @default("PUBLIC")
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId, startsAt])
  @@index([companyId, publicCode])
  @@index([serviceId])
}

model Quote {
  id              String      @id @default(uuid())
  code            String?     @unique
  sequence        Int?
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?    @relation(fields: [vehicleId], references: [id])
  title           String
  status          QuoteStatus @default(DRAFT)
  subtotalCents   Int         @default(0)
  discountCents   Int         @default(0)
  totalCents      Int         @default(0)
  validUntil      DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items       QuoteItem[]
  workOrders  WorkOrder[]

  @@index([companyId])
  @@index([clientId])
}

model QuoteItem {
  id             String   @id @default(uuid())
  quoteId        String
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service? @relation(fields: [serviceId], references: [id])
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  totalCents     Int      @default(0)
}

model WorkOrder {
  id         String          @id @default(uuid())
  code       String?         @unique
  sequence   Int?
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id])
  quoteId    String?
  quote      Quote?          @relation(fields: [quoteId], references: [id])
  clientId   String
  vehicleId  String?
  vehicle    Vehicle?        @relation(fields: [vehicleId], references: [id])
  status     WorkOrderStatus @default(OPEN)
  checklist  Json?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([companyId])
}

model Product {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  name           String
  brand          String?
  type           String?
  shade          String?
  line           String?
  unit           String   @default("un")
  costCents      Int      @default(0)
  stockQuantity  Decimal  @default(0)
  minStock       Decimal  @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockMovements StockMovement[]

  @@index([companyId])
}

model StockMovement {
  id          String            @id @default(uuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
  type        StockMovementType
  quantity    Decimal
  reason      String?
  createdAt   DateTime          @default(now())

  @@index([companyId])
  @@index([productId])
}

model FinancialEntry {
  id             String          @id @default(uuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  type           FinancialType
  description    String
  category       String
  amountCents    Int
  paymentMethod  PaymentMethod?
  status         FinancialStatus @default(PENDING)
  dueDate        DateTime?
  paidAt         DateTime?
  referenceId    String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([type, status])
}

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([entity, entityId])
}

model Setting {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
}
