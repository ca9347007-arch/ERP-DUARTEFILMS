{
  "name": "duartefilms-erp",
  "version": "0.1.0",
  "private": true,
  "description": "ERP operacional DuarteFilms - starter local",
  "scripts": {
    "dev": "pnpm --parallel --filter @duartefilms/api --filter @duartefilms/web dev",
    "dev:api": "pnpm --filter @duartefilms/api dev",
    "dev:web": "pnpm --filter @duartefilms/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @duartefilms/api prisma:generate",
    "db:migrate": "pnpm --filter @duartefilms/api prisma:migrate",
    "db:seed": "pnpm --filter @duartefilms/api prisma:seed",
    "db:studio": "pnpm --filter @duartefilms/api prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.6.0"
}
